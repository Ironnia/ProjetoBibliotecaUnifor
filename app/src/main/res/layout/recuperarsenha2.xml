<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="700dp"
        tools:context=".NovaSenhaActivity">

        <!-- ===== CABEÇALHO COM GRADIENTE AZUL ===== -->
        <View
            android:id="@+id/viewHeader"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:background="@drawable/bg_header_gradient"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Círculo decorativo atrás do logo -->
        <View
            android:id="@+id/viewCircleLogo"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_circle_white"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="@id/viewHeader"
            app:layout_constraintBottom_toBottomOf="@id/viewHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.55" />

        <!-- Logo da Universidade -->
        <ImageView
            android:id="@+id/imageViewLogo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="centerInside"
            android:elevation="6dp"
            app:srcCompat="@drawable/logo_unifor"
            app:layout_constraintTop_toTopOf="@id/viewCircleLogo"
            app:layout_constraintBottom_toBottomOf="@id/viewCircleLogo"
            app:layout_constraintStart_toStartOf="@id/viewCircleLogo"
            app:layout_constraintEnd_toEndOf="@id/viewCircleLogo" />

        <!-- Nome da universidade -->
        <TextView
            android:id="@+id/textViewUniversidade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Universidade de Fortaleza"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:alpha="0.9"
            android:letterSpacing="0.08"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/viewCircleLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ===== CARD BRANCO DO FORMULÁRIO ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/viewHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0.0">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="32dp">

                <!-- Título -->
                <TextView
                    android:id="@+id/textViewTitulo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Recupere a senha"
                    android:textSize="37sp"
                    android:textColor="#1A237E"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:fontFamily="sans-serif-black"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Linha decorativa -->
                <View
                    android:id="@+id/viewDivider"
                    android:layout_width="48dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_divider_rounded"
                    android:layout_marginTop="2dp"
                    app:layout_constraintTop_toBottomOf="@id/textViewTitulo"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Subtítulo -->
                <TextView
                    android:id="@+id/textViewSubtitulo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Crie uma senha forte com pelo menos 8 caracteres."
                    android:textSize="14sp"
                    android:textColor="#757575"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/viewDivider"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Campo Nova Senha -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutNovaSenha"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                    app:startIconTint="#1565C0"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#9E9E9E"
                    app:boxStrokeColor="#1565C0"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:hintTextColor="#1565C0"
                    app:layout_constraintTop_toBottomOf="@id/textViewSubtitulo"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextNovaSenha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nova senha"
                        android:inputType="textPassword"
                        android:imeOptions="actionNext"
                        android:textSize="15sp"
                        android:paddingStart="4dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Indicador de força da senha -->
                <LinearLayout
                    android:id="@+id/layoutForcaSenha"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    app:layout_constraintTop_toBottomOf="@id/layoutNovaSenha"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <View
                        android:id="@+id/barForca1"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_divider_rounded"
                        android:layout_marginEnd="4dp" />

                    <View
                        android:id="@+id/barForca2"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_divider_rounded"
                        android:alpha="0.3"
                        android:layout_marginEnd="4dp" />

                    <View
                        android:id="@+id/barForca3"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_divider_rounded"
                        android:alpha="0.3"
                        android:layout_marginEnd="4dp" />

                    <View
                        android:id="@+id/barForca4"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_divider_rounded"
                        android:alpha="0.3" />

                    <TextView
                        android:id="@+id/textForcaSenha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fraca"
                        android:textSize="11sp"
                        android:textColor="#1565C0"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Campo Confirmar Senha -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutConfirmarSenha"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                    app:startIconTint="#1565C0"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#9E9E9E"
                    app:boxStrokeColor="#1565C0"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:hintTextColor="#1565C0"
                    app:layout_constraintTop_toBottomOf="@id/layoutForcaSenha"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextConfirmarSenha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Confirme a nova senha"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:textSize="15sp"
                        android:paddingStart="4dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botão Redefinir senha -->
                <Button
                    android:id="@+id/buttonRedefinir"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginTop="28dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:text="Redefinir senha"
                    android:textSize="17sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:backgroundTint="#1565C0"
                    android:stateListAnimator="@null"
                    android:elevation="6dp"
                    app:cornerRadius="26dp"
                    app:layout_constraintTop_toBottomOf="@id/layoutConfirmarSenha"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>