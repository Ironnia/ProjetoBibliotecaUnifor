<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="#EEEEEE"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_mesa_nome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/iv_status"
                android:text="Mesa 15 - 2º andar"
                android:textColor="@color/unifor_marinho_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/iv_status"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_green" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/calendar_clock_24"
                app:tint="#888888" />

            <TextView
                android:id="@+id/tv_mesa_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Livre até 10:40"
                android:textColor="#888888"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Botão Opções -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_opcoes"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:text="Opções"
            android:textSize="12sp"
            app:cornerRadius="8dp"
            app:strokeColor="@color/unifor_anil_primary" />

        <!-- Ações expandíveis (hidden by default) -->
        <LinearLayout
            android:id="@+id/layout_acoes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- antigo: android:text="Liberar" -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_liberar"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Liberar tudo"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/success_green"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_gerenciar_horarios"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Gerenciar Horários"
                android:textSize="11sp"
                app:cornerRadius="8dp"
                app:strokeColor="@color/unifor_anil_primary" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
