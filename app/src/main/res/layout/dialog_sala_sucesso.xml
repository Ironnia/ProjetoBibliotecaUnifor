<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_success_check" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Sala reservada com sucesso!"
        android:textColor="@color/unifor_marinho_dark"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/tv_success_data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Data: 15/04"
            android:textColor="#333333"
            android:textSize="16sp"
            android:drawableStart="@android:drawable/ic_menu_myplaces"
            android:drawablePadding="8dp" />

        <TextView
            android:id="@+id/tv_success_horario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Horário: 09:00 - 11:30"
            android:textColor="#333333"
            android:textSize="16sp"
            android:drawableStart="@android:drawable/ic_menu_recent_history"
            android:drawablePadding="8dp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_success_voltar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Voltar"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/unifor_anil_primary" />

</LinearLayout>
