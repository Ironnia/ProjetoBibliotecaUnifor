<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="700dp"
        tools:context=".LoginActivity">

        <!-- ===== CABEÇALHO COM GRADIENTE AZUL ===== -->
        <View
            android:id="@+id/viewHeader"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:background="@drawable/bg_header_gradient"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Círculo decorativo atrás do logo -->
        <View
            android:id="@+id/viewCircleLogo"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_circle_white"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="@id/viewHeader"
            app:layout_constraintBottom_toBottomOf="@id/viewHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.55" />

        <!-- Logo da Universidade -->
        <ImageView
            android:id="@+id/imageViewLogo"
            android:layout_width="120dp"
            android:layout_height="60dp"
            android:scaleType="centerInside"
            android:elevation="6dp"
            app:srcCompat="@drawable/ic_unifor_logo"
            app:layout_constraintTop_toTopOf="@id/viewCircleLogo"
            app:layout_constraintBottom_toBottomOf="@id/viewCircleLogo"
            app:layout_constraintStart_toStartOf="@id/viewCircleLogo"
            app:layout_constraintEnd_toEndOf="@id/viewCircleLogo" />

        <!-- Nome da universidade -->
        <TextView
            android:id="@+id/textViewUniversidade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Universidade de Fortaleza"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:alpha="0.9"
            android:letterSpacing="0.08"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/viewCircleLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ===== CARD BRANCO DO FORMULÁRIO ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/viewHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0.0">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="32dp">

                <!-- Título LOGIN -->
                <TextView
                    android:id="@+id/textViewLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Login"
                    android:textSize="42sp"
                    android:textColor="#1A237E"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:fontFamily="sans-serif-black"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Linha decorativa abaixo do Login -->
                <View
                    android:id="@+id/viewDivider"
                    android:layout_width="48dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_divider_rounded"
                    android:layout_marginTop="2dp"
                    app:layout_constraintTop_toBottomOf="@id/textViewLogin"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Campo Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutEmail"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:errorEnabled="false"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="@color/unifor_anil_primary"
                    app:boxStrokeColor="@color/unifor_anil_primary"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:hintTextColor="@color/unifor_anil_primary"
                    app:layout_constraintTop_toBottomOf="@id/viewDivider"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="E-mail"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:nextFocusForward="@id/editTextSenha"
                        android:textSize="15sp"
                        android:paddingStart="4dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Senha -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutSenha"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:errorEnabled="false"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                    app:startIconTint="#1565C0"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#9E9E9E"
                    app:boxStrokeColor="#1565C0"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:hintTextColor="#1565C0"
                    app:layout_constraintTop_toBottomOf="@id/layoutEmail"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextSenha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Senha"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:nextFocusForward="@id/checkBoxLembrar"
                        android:textSize="15sp"
                        android:paddingStart="4dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Linha: cadastro + lembrar-me -->
                <TextView
                    android:id="@+id/textViewNaoCadastro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Não tem cadastro? "
                    android:textSize="12sp"
                    android:textColor="#757575"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toBottomOf="@id/layoutSenha"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/textViewCadastrarAqui"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="cadastre-se aqui"
                    android:textSize="12sp"
                    android:textColor="@color/unifor_anil_primary"
                    android:textStyle="bold"
                    app:layout_constraintBaseline_toBaselineOf="@id/textViewNaoCadastro"
                    app:layout_constraintStart_toEndOf="@id/textViewNaoCadastro" />

                <CheckBox
                    android:id="@+id/checkBoxLembrar"
                    android:nextFocusForward="@id/buttonEntrar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lembrar-me"
                    android:textSize="12sp"
                    android:textColor="#757575"
                    android:button="@drawable/bg_checkbox_custom"
                    android:paddingStart="8dp"
                    app:layout_constraintBaseline_toBaselineOf="@id/textViewNaoCadastro"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Esqueci senha -->
                <TextView
                    android:id="@+id/textViewEsqueciSenha"
                    android:nextFocusForward="@id/textViewCadastrarAqui"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Esqueci minha senha"
                    android:textSize="12sp"
                    android:textColor="@color/unifor_anil_primary"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp"
                    app:layout_constraintTop_toBottomOf="@id/textViewNaoCadastro"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Botão Entrar -->
                <Button
                    android:id="@+id/buttonEntrar"
                    android:nextFocusForward="@id/textViewEsqueciSenha"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginTop="28dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:text="Entrar"
                    android:textSize="17sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:backgroundTint="@color/unifor_anil_primary"
                    android:stateListAnimator="@null"
                    android:elevation="6dp"
                    app:cornerRadius="26dp"
                    app:layout_constraintTop_toBottomOf="@id/textViewEsqueciSenha"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:indeterminateTint="@color/unifor_anil_primary"
                    app:layout_constraintTop_toTopOf="@id/buttonEntrar"
                    app:layout_constraintBottom_toBottomOf="@id/buttonEntrar"
                    app:layout_constraintStart_toStartOf="@id/buttonEntrar"
                    app:layout_constraintEnd_toEndOf="@id/buttonEntrar" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
